{
  "name": "example-ecommerce",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunflare dev",
    "preview": "wrangler preview",
    "start": "NODE_ENV=production bun src/index.ts",
    "build": "bun --bun run bunflare build",
    "deploy": "bunflare deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply ecommerce-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply ecommerce-db --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.6",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/query": "latest",
    "@nanostores/react": "latest",
    "@nanostores/router": "latest",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "bunflare": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "latest",
    "hono": "^4.6.14",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "nanostores": "latest",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/bun": "latest",
    "drizzle-kit": "latest",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.4.0",
    "wrangler": "latest"
  }
}
