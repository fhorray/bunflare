{
  "name": "example-bun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "dev:cf": "wrangler dev --port 3103 --inspector-port 9203",
    "build": "bun --bun run buncf build",
    "deploy": "bun run build --production && wrangler deploy"
  },
  "dependencies": {
    "buncf": "workspace:*",
    "wrangler": "latest"
  }
}
