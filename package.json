{
  "name": "bunflare-plugin",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check-types": "tsc --noEmit",
    "publish": "bun run scripts/publish.ts",
    "dev:cf": "turbo dev:cf"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@types/bun": "latest",
    "picocolors": "^1.1.1",
    "turbo": "^2.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
