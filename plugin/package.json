{
  "name": "bunflare",
  "version": "0.2.5",
  "description": "Bunflare plugin for full-stack Cloudflare Workers applications",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "bunflare": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "assets/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:lib": "bun build src/index.ts src/hono.ts --outdir ./dist --format esm",
    "build:cli": "bun build src/cli/index.ts --outfile ./dist/cli/index.js --target bun",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:lib && bun run build:cli && bun run build:types"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "import": "./dist/hono.js"
    }
  },
  "typesVersions": {
    "*": {
      "hono": ["./dist/hono.d.ts"],
      "*": ["./dist/*.d.ts"]
    }
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "livereload": "^0.10.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/livereload": "^0.9.5",
    "hono": "^4.12.16"
  }
}
