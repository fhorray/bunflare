{
  "name": "bunflare",
  "version": "0.2.5",
  "description": "Bunflare plugin for full-stack Cloudflare Workers applications",
  "main": "src/index.ts",
  "bin": {
    "bunflare": "./src/cli/index.ts"
  },
  "files": [
    "src/",
    "assets/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir ./dist"
  },
  "exports": {
    ".": "./src/index.ts",
    "./hono": "./src/hono.ts",
    "./*": "./src/*.ts"
  },
  "typesVersions": {
    "*": {
      "hono": [
        "./src/hono.ts"
      ],
      "*": [
        "./src/*.ts"
      ]
    }
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "livereload": "^0.10.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/livereload": "^0.9.5",
    "hono": "^4.12.16"
  }
}
